/**
 * Core Philosophy: This ruleset enforces a multi-tenant security model for a B2B ordering platform.
 * There are two primary entities: 'Wholesalers' and 'Stores'. Each entity has its own set of managing users
 * (owners, admins, managers). Access to data is granted based on a user's role within one of these entities.
 *
 * Data Structure: Data is segregated into two main types:
 * 1. Owned Data: Nested in subcollections under `/wholesalers/{wholesalerId}` or `/stores/{storeId}`.
 *    This data is exclusively managed by the members of the parent entity.
 * 2. Collaborative Data: Stored in top-level collections (`/orders`, `/supplierStoreRequests`, etc.).
 *    These documents represent interactions between a Wholesaler and a Store and are accessible to
 *    members of both participating entities.
 *
 * Key Security Decisions:
 * - Authorization Independence: Every document contains denormalized ownership and role information (e.g.,
 *   `ownerId`, `adminUids`, `storeOwnerId`, `wholesalerOwnerId`). This avoids slow and costly `get()`
 *   calls for most authorization checks, leading to simpler, more performant rules.
 * - Subcollection Security: Access to list or create items in a subcollection requires a single `get()`
 *   call to the parent document to verify membership, a standard and secure pattern. All other operations
 *   rely on the denormalized auth fields within the document itself.
 * - No Public Access: All operations require user authentication. There are no publicly readable collections.
 * - Strict Writes: All write operations (`create`, `update`, `delete`) are strictly controlled. Updates and
 *   deletes always verify that the document exists before proceeding. Relational integrity fields (e.g., `storeId`,
 *   `wholesalerId`) are immutable after creation.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------------------------------------------
    // Helper Functions
    // --------------------------------------------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user is a member (owner or admin) of a Wholesaler.
     * @param docData The document data map which must contain `ownerId` and `adminUids`.
     */
    function isWholesalerMember(docData) {
      return isSignedIn() && (request.auth.uid == docData.ownerId || request.auth.uid in docData.adminUids);
    }

    /**
     * Checks if an existing document can be accessed by a Wholesaler member.
     * @param docData The document data map which must contain `ownerId` and `adminUids`.
     */
    function isExistingWholesalerMember(docData) {
      return resource != null && isWholesalerMember(docData);
    }

    /**
     * Checks if the authenticated user is a member (owner or manager) of a Store.
     * @param docData The document data map which must contain `ownerId` and `managerUids`.
     */
    function isStoreMember(docData) {
      return isSignedIn() && (request.auth.uid == docData.ownerId || request.auth.uid in docData.managerUids);
    }

    /**
     * Checks if an existing document can be accessed by a Store member.
     * @param docData The document data map which must contain `ownerId` and `managerUids`.
     */
    function isExistingStoreMember(docData) {
      return resource != null && isStoreMember(docData);
    }

    /**
     * Checks if the user is a member of either the Store or Wholesaler party in a collaborative document.
     * @param docData The document data map which must contain denormalized auth fields for both parties.
     */
    function isEitherPartyMember(docData) {
      return isSignedIn() && (
        (request.auth.uid == docData.storeOwnerId || (docData.keys().hasAny(['storeManagerUids']) && request.auth.uid in docData.storeManagerUids)) ||
        (request.auth.uid == docData.wholesalerOwnerId || (docData.keys().hasAny(['wholesalerAdminUids']) && request.auth.uid in docData.wholesalerAdminUids))
      );
    }
    
    function isBusinessOwner(businessId, businessType) {
      let path = businessType == 'store' ? /databases/$(database)/documents/stores/$(businessId) : /databases/$(database)/documents/wholesalers/$(businessId);
      let doc = get(path).data;
      return (businessType == 'store' && isStoreMember(doc)) || (businessType == 'wholesaler' && isWholesalerMember(doc));
    }


    /**
     * Checks if an existing collaborative document can be accessed by a member of either party.
     * @param docData The document data map.
     */
    function isExistingEitherPartyMember(docData) {
      return resource != null && isEitherPartyMember(docData);
    }

    /**
     * Verifies a user has rights to access a Wholesaler's subcollection (for list/create).
     * This performs a single get() on the parent document.
     */
    function canAccessWholesalerSubcollection(wholesalerId) {
      let wholesalerDoc = get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data;
      return isSignedIn() && (request.auth.uid == wholesalerDoc.ownerId || request.auth.uid in wholesalerDoc.adminUids);
    }

    /**
     * Verifies a user has rights to access a Store's subcollection (for list/create).
     * This performs a single get() on the parent document.
     */
    function canAccessStoreSubcollection(storeId) {
      let storeDoc = get(/databases/$(database)/documents/stores/$(storeId)).data;
      return isSignedIn() && (request.auth.uid == storeDoc.ownerId || request.auth.uid in storeDoc.managerUids);
    }

    /**
     * Verifies a user has rights to access an Order's subcollection (for list/create).
     * This performs a single get() on the parent document.
     */
    function canAccessOrderSubcollection(orderId) {
      let orderDoc = get(/databases/$(database)/documents/orders/$(orderId)).data;
      return isSignedIn() && isEitherPartyMember(orderDoc);
    }

    // --------------------------------------------------------------------
    // Wholesaler Collections
    // --------------------------------------------------------------------

    /**
     * @description Manages a wholesaler's primary profile.
     * @path /wholesalers/{wholesalerId}
     * @allow (get) A user who is the owner or an admin of the wholesaler.
     * @deny (list) Listing all wholesalers in the system is not permitted.
     * @principle Restricts access to entity members via denormalized `ownerId` and `adminUids` fields.
     */
    match /wholesalers/{wholesalerId} {
      allow get: if isWholesalerMember(resource.data);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingWholesalerMember(resource.data);
      allow delete: if isExistingWholesalerMember(resource.data);

      /**
       * @description A wholesaler's product catalog.
       * @path /wholesalers/{wholesalerId}/products/{productId}
       * @allow (create) An authenticated member of the parent wholesaler.
       * @deny (update) A user who is not a member of this wholesaler.
       * @principle Subcollection access is granted based on membership in the parent entity.
       */
      match /products/{productId} {
        allow get: if isWholesalerMember(resource.data);
        allow list: if canAccessWholesalerSubcollection(wholesalerId);
        allow create: if canAccessWholesalerSubcollection(wholesalerId) && request.resource.data.wholesalerId == wholesalerId;
        allow update: if isExistingWholesalerMember(resource.data) && request.resource.data.wholesalerId == resource.data.wholesalerId;
        allow delete: if isExistingWholesalerMember(resource.data);
      }
      
      /**
       * @description A wholesaler's physical warehouses.
       * @path /wholesalers/{wholesalerId}/warehouses/{warehouseId}
       * @principle Subcollection access is granted based on membership in the parent entity.
       */
      match /warehouses/{warehouseId} {
        allow list, get: if canAccessWholesalerSubcollection(wholesalerId);
        allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
        allow update: if isWholesalerMember(resource.data);
        allow delete: if isWholesalerMember(resource.data);

        /**
         * @description Inventory records for products within a specific warehouse.
         * @path /wholesalers/{wholesalerId}/warehouses/{warehouseId}/inventories/{inventoryId}
         * @principle Access is granted based on membership in the grandparent wholesaler entity.
         */
        match /inventories/{inventoryId} {
            allow get, list: if canAccessWholesalerSubcollection(wholesalerId);
            allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
            allow update: if isWholesalerMember(resource.data) && request.resource.data.wholesalerId == resource.data.wholesalerId && request.resource.data.warehouseId == resource.data.warehouseId;
            allow delete: if isWholesalerMember(resource.data);
        }
      }
    }

    // --------------------------------------------------------------------
    // Store Collections
    // --------------------------------------------------------------------

    /**
     * @description Manages a store's primary profile.
     * @path /stores/{storeId}
     * @allow (get) A user who is the owner or a manager of the store.
     * @deny (list) Listing all stores in the system is not permitted.
     * @principle Restricts access to entity members via denormalized `ownerId` and `managerUids` fields.
     */
    match /stores/{storeId} {
      allow get: if isStoreMember(resource.data);
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingStoreMember(resource.data);
      allow delete: if isExistingStoreMember(resource.data);

      /**
       * @description Store-specific configurations for products.
       * @path /stores/{storeId}/productConfigurations/{configId}
       * @allow (get) A member of the parent store can view their product configurations.
       * @deny (update) A user from a different store.
       * @principle Subcollection access is granted based on membership in the parent entity.
       */
      match /productConfigurations/{configId} {
        allow get: if isStoreMember(resource.data);
        allow list: if canAccessStoreSubcollection(storeId);
        allow create: if isSignedIn() && request.resource.data.storeId == storeId && request.resource.data.ownerId == request.auth.uid;
        allow update: if isExistingStoreMember(resource.data) && request.resource.data.storeId == resource.data.storeId;
        allow delete: if isExistingStoreMember(resource.data);
      }

      /**
       * @description A store's product inventory records.
       * @path /stores/{storeId}/inventories/{storeInventoryId}
       * @allow (get) An authenticated member of the parent store.
       * @deny (get) A member of a wholesaler or another store.
       * @principle Subcollection access is granted based on membership in the parent entity.
       */
      match /inventories/{storeInventoryId} {
        allow get, list: if canAccessStoreSubcollection(storeId);
        allow create: if canAccessStoreSubcollection(storeId) && request.resource.data.storeId == storeId && request.resource.data.ownerId == request.auth.uid;
        allow update: if canAccessStoreSubcollection(storeId) && request.resource.data.storeId == resource.data.storeId && request.resource.data.ownerId == request.auth.uid;
        allow delete: if canAccessStoreSubcollection(storeId);
      }
    }

    // --------------------------------------------------------------------
    // Collaborative Collections
    // --------------------------------------------------------------------
    
    match /joinRequests/{requestId} {
      allow create: if true; // Public submission form
      allow get: if isSignedIn() && isBusinessOwner(resource.data.businessId, resource.data.businessType);
      allow list: if isSignedIn();
      allow update, delete: if isSignedIn() && isBusinessOwner(resource.data.businessId, resource.data.businessType);
    }

    /**
     * @description Manages connection requests between stores and wholesalers.
     * @path /supplierStoreRequests/{requestId}
     * @allow (get) A user who is a member of either the requesting store or the target wholesaler.
     * @deny (get) A user not associated with either party.
     * @principle Secures collaborative documents by checking membership of either participating entity.
     */
    match /supplierStoreRequests/{requestId} {
      allow get: if isEitherPartyMember(resource.data);
      allow list: if isSignedIn();
      allow create: if isEitherPartyMember(request.resource.data);
      allow update: if isExistingEitherPartyMember(resource.data);
      allow delete: if isExistingEitherPartyMember(resource.data);
    }

    /**
     * @description Manages active connections between stores and wholesalers.
     * @path /supplierStoreConnections/{connectionId}
     * @allow (get) A user who is a member of either the connected store or wholesaler.
     * @deny (delete) A user trying to delete a connection they are not part of.
     * @principle Secures collaborative documents by checking membership of either participating entity.
     */
    match /supplierStoreConnections/{connectionId} {
      allow get: if isEitherPartyMember(resource.data);
      allow list: if isSignedIn();
      allow create: if isEitherPartyMember(request.resource.data);
      allow update: if isExistingEitherPartyMember(resource.data);
      allow delete: if isExistingEitherPartyMember(resource.data);
    }

    /**
     * @description Represents an order placed by a store to a wholesaler.
     * @path /orders/{orderId}
     * @allow (get) A user who is a member of the store that placed the order or the wholesaler that received it.
     * @deny (update) An unrelated third-party user trying to modify the order status.
     * @principle Secures collaborative documents by checking membership of either participating entity.
     */
    match /orders/{orderId} {
      allow get: if isEitherPartyMember(resource.data);
      allow list: if isSignedIn();
      allow create: if isEitherPartyMember(request.resource.data);
      allow update: if isExistingEitherPartyMember(resource.data) && request.resource.data.storeId == resource.data.storeId && request.resource.data.wholesalerId == resource.data.wholesalerId;
      allow delete: if isExistingEitherPartyMember(resource.data);

      /**
       * @description Individual line items within an order.
       * @path /orders/{orderId}/items/{orderItemId}
       * @allow (list) A member of the store or wholesaler associated with the parent order.
       * @deny (create) A user not associated with the parent order.
       * @principle Subcollection access is granted based on membership in the parent collaborative entity.
       */
      match /items/{orderItemId} {
        allow get: if isEitherPartyMember(resource.data);
        allow list: if canAccessOrderSubcollection(orderId);
        allow create: if canAccessOrderSubcollection(orderId) && request.resource.data.orderId == orderId;
        allow update: if isExistingEitherPartyMember(resource.data) && request.resource.data.orderId == resource.data.orderId;
        allow delete: if isExistingEitherPartyMember(resource.data);
      }
    }
  }
}
