rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isWholesalerMember(docData) {
      return isSignedIn() && docData != null && (
        docData.ownerId == request.auth.uid || 
        (docData.adminUids is list && request.auth.uid in docData.adminUids)
      );
    }
    
    function isExistingWholesalerMember(docData) {
      return resource != null && isWholesalerMember(docData);
    }

    function isStoreMember(docData) {
      return isSignedIn() && docData != null && (
        docData.ownerId == request.auth.uid || 
        (docData.managerUids is list && request.auth.uid in docData.managerUids)
      );
    }

    function isExistingStoreMember(docData) {
      return resource != null && isStoreMember(docData);
    }

    function isEitherPartyMember(docData) {
      return isSignedIn() && (
        (request.auth.uid == docData.storeOwnerId || (docData.storeManagerUids is list && request.auth.uid in docData.storeManagerUids)) ||
        (request.auth.uid == docData.wholesalerOwnerId || (docData.wholesalerAdminUids is list && request.auth.uid in docData.wholesalerAdminUids))
      );
    }
    
    function isBusinessOwner(businessId, businessType) {
      let path = businessType == 'store' ? /databases/$(database)/documents/stores/$(businessId) : /databases/$(database)/documents/wholesalers/$(businessId);
      return exists(path) && (
        (businessType == 'store' && isStoreMember(get(path).data)) || 
        (businessType == 'wholesaler' && isWholesalerMember(get(path).data))
      );
    }

    function isWholesalerMemberById(wholesalerId) {
      let path = /databases/$(database)/documents/wholesalers/$(wholesalerId);
      return exists(path) && (
        get(path).data.ownerId == request.auth.uid || 
        (get(path).data.adminUids is list && request.auth.uid in get(path).data.adminUids)
      );
    }

    function isExistingEitherPartyMember(docData) {
      return resource != null && isEitherPartyMember(docData);
    }

    match /wholesalers/{wholesalerId} {
      allow get: if isWholesalerMember(resource.data) || 
                   (isSignedIn() && resource.data.parentWholesalerId is string && isWholesalerMemberById(resource.data.parentWholesalerId));
      allow list: if true; // Public: allows unauthenticated AFM search on login page
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if isExistingWholesalerMember(resource.data) || 
                   (isSignedIn() && resource.data.email == request.auth.token.email);
      allow delete: if isExistingWholesalerMember(resource.data);

      match /productConfigurations/{configId} {
        allow read: if isWholesalerMemberById(wholesalerId) || 
                       (isSignedIn() && get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data.parentWholesalerId is string && 
                        isWholesalerMemberById(get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data.parentWholesalerId));
        allow write: if isWholesalerMemberById(wholesalerId) || 
                        (isSignedIn() && get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data.parentWholesalerId is string && 
                         isWholesalerMemberById(get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data.parentWholesalerId));
      }

      match /products/{productId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn() && (
          get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data.ownerId == request.auth.uid || 
          (get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data.adminUids is list && 
           request.auth.uid in get(/databases/$(database)/documents/wholesalers/$(wholesalerId)).data.adminUids)
        );
      }
      
      match /warehouses/{warehouseId} {
        allow read, write: if isSignedIn();
        match /inventories/{inventoryId} {
          allow read, write: if isSignedIn();
        }
      }
      
      match /postits/{postitId} {
        allow read, write: if isSignedIn();
      }

      match /scanBaseProducts/{productId} {
        allow read, write: if isSignedIn();
      }
    }

    match /stores/{storeId} {
      allow get: if isSignedIn();
      allow list: if true; // Public: allows unauthenticated AFM search on login page
      allow create: if isSignedIn() && (
        request.resource.data.ownerId == request.auth.uid || 
        (request.resource.data.wholesalerIds is list && request.resource.data.wholesalerIds.size() > 0 && isWholesalerMemberById(request.resource.data.wholesalerIds[0]))
      );
      allow update: if isExistingStoreMember(resource.data) || 
                   (isSignedIn() && resource.data.email == request.auth.token.email) ||
                   (resource.data.wholesalerIds is list && resource.data.wholesalerIds.size() > 0 && isWholesalerMemberById(resource.data.wholesalerIds[0]));
      allow delete: if isExistingStoreMember(resource.data) || 
                   (resource.data.wholesalerIds is list && resource.data.wholesalerIds.size() > 0 && isWholesalerMemberById(resource.data.wholesalerIds[0]));

      match /productConfigurations/{configId} {
        allow read, write: if isSignedIn();
      }

      match /inventories/{storeInventoryId} {
         allow read, write: if isSignedIn();
      }

      match /reminders/{reminderId} {
        allow read, write: if isSignedIn() && (
          (resource == null && request.resource.data.ownerId == request.auth.uid) ||
          (resource != null && resource.data.ownerId == request.auth.uid)
        );
      }
    }

    match /joinRequests/{requestId} {
      allow create: if true; 
      // Allow read if user owns the business, or if the request targets their wholesaler/store
      allow get, list: if isSignedIn();
      // Allow update/delete if user is business owner OR if the request has their wholesalerId
      allow update, delete: if isSignedIn() && (
        isBusinessOwner(resource.data.businessId, resource.data.businessType) ||
        isWholesalerMemberById(resource.data.wholesalerId) ||
        (resource.data.wholesalerId is string && isWholesalerMemberById(resource.data.wholesalerId))
      );
    }

    match /supplierStoreRequests/{requestId} {
      allow get: if isEitherPartyMember(resource.data);
      allow list: if isSignedIn();
      allow create: if isEitherPartyMember(request.resource.data);
      allow update, delete: if isExistingEitherPartyMember(resource.data);
    }

    match /supplierStoreConnections/{connectionId} {
      // Allow any signed-in user to read connections. Client queries are always
      // constrained by wholesalerId or storeId so only relevant data is returned.
      allow read: if isSignedIn();
      allow create: if isEitherPartyMember(request.resource.data) || isWholesalerMemberById(request.resource.data.wholesalerId);
      allow update, delete: if isExistingEitherPartyMember(resource.data);
    }

    match /orders/{orderId} {
      allow get, delete, update: if isSignedIn() && resource.data.memberUids is list && request.auth.uid in resource.data.memberUids;
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.memberUids is list && request.auth.uid in request.resource.data.memberUids;

      match /items/{orderItemId} {
        allow read, write: if get(/databases/$(database)/documents/orders/$(orderId)).data.memberUids is list && request.auth.uid in get(/databases/$(database)/documents/orders/$(orderId)).data.memberUids;
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.recipientUid == request.auth.uid;
    }
    
    match /fcmTokens/{tokenId} {
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
  }
}